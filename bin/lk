#!/usr/bin/env sh
# Point d'entrée unique du moteur LinkedIn lead-gen.
# Les commandes RÉSEAU sont lancées sous xvfb (navigateur headful sans écran) ;
# les commandes hors-ligne (profile/geo/leads/export/rescore/status) tournent direct.
set -eu
ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
NET=" seed-cookies login whoami search-posts search-people comments campaign resolve resolve-pending "
case "$NET" in
  *" ${1:-help} "*) exec xvfb-run -a npx tsx "$ROOT/src/cli.ts" "$@" ;;
  *)                exec npx tsx "$ROOT/src/cli.ts" "$@" ;;
esac
